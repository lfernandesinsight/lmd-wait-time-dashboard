# --- Opção A: container Postgres local (dev) — "postgres_dev" (porta 5433) ---
POSTGRES_USER=dev
POSTGRES_PASSWORD=dev
POSTGRES_DB=lmd_dashboard
POSTGRES_HOST=localhost
POSTGRES_PORT=5433

# --- Opção B: Neon (produção, usado pelo GitHub Actions e pelo Grafana Cloud) ---
# Não precisa preencher isso localmente — no seu .env pessoal, comente/apague
# e use a Opção A acima. Isto aqui é só documentação de referência.
# DATABASE_URL=postgresql://<usuario>:<senha>@ep-cool-sunset-atkz9jck.c-9.us-east-1.aws.neon.tech/neondb?sslmode=require

# Caminho local do xlsx (modo --source local)
XLSX_PATH=./data/Cidadania_espanhola_SP.xlsx
XLSX_SHEET_NAME=Citas Marcadas

# Fonte de dados: "local" (lê o xlsx acima) ou "sheets" (baixa direto do
# Google Sheets público — usado automaticamente pelo GitHub Actions)
SOURCE=local
